rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ⚠️ DEVELOPMENT MODE - Set to false before production!
    // When true, allows unrestricted writes for seeding data
    function isDevMode() {
      return true; // Set to false before deploying to production
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      allow read: if isDevMode() || isAuthenticated();
      allow create: if isDevMode() || isOwner(userId);
      allow update: if isDevMode() || isOwner(userId);
      allow delete: if isDevMode() || isOwner(userId);
    }
    
    // ==================== RIDES COLLECTION ====================
    match /rides/{rideId} {
      allow read: if isDevMode() || isAuthenticated();
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.driverId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
    }
    
    // ==================== CHATS COLLECTION ====================
    match /chats/{chatId} {
      allow read: if isDevMode() || (isAuthenticated() && request.auth.uid in resource.data.participantIds);
      allow create: if isDevMode() || (isAuthenticated() && request.auth.uid in request.resource.data.participantIds);
      allow update: if isDevMode() || (isAuthenticated() && request.auth.uid in resource.data.participantIds);
      allow delete: if isDevMode();
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isDevMode() || isAuthenticated();
      }
      
      // Typing indicators subcollection
      match /typing/{typingId} {
        allow read, write: if isDevMode() || isAuthenticated();
      }
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    match /notifications/{notificationId} {
      allow read: if isDevMode() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isDevMode();
      allow update: if isDevMode() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // ==================== VEHICLES COLLECTION ====================
    match /vehicles/{vehicleId} {
      allow read: if isDevMode() || isAuthenticated();
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }
    
    // ==================== CALLS COLLECTION (WebRTC Signaling) ====================
    match /calls/{callId} {
      allow read: if isDevMode() || (isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid));
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.callerId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid));
      
      match /callerCandidates/{candidateId} {
        allow read, write: if isDevMode() || isAuthenticated();
      }
      
      match /calleeCandidates/{candidateId} {
        allow read, write: if isDevMode() || isAuthenticated();
      }
    }
    
    // ==================== DRIVER STATS COLLECTION ====================
    match /driver_stats/{driverId} {
      allow read: if isDevMode() || isAuthenticated();
      allow write: if isDevMode() || (isAuthenticated() && driverId == request.auth.uid);
    }
    
    // ==================== HOTSPOTS COLLECTION ====================
    match /hotspots/{hotspotId} {
      allow read: if isDevMode() || isAuthenticated();
      allow write: if isDevMode(); // Seeding allowed in dev mode
    }
    
    // ==================== LEADERBOARD COLLECTION ====================
    match /leaderboard/{entryId} {
      allow read: if isDevMode() || isAuthenticated();
      allow write: if isDevMode(); // Seeding allowed in dev mode
    }
    
    // ==================== TRANSACTIONS COLLECTION ====================
    match /transactions/{transactionId} {
      // Allow the driver to read their own transactions
      allow read: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.driverId == request.auth.uid);
      allow update, delete: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
    }

    // Support transactions in subcollections as collectionGroup queries
    match /{path=**}/transactions/{transactionId} {
      allow read: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.driverId == request.auth.uid);
      allow update, delete: if isDevMode() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
    }

    // ==================== DRIVER CONNECTED ACCOUNTS COLLECTION ====================
    // Used for Stripe connected accounts for drivers
    match /driver_connected_accounts/{userId} {
      allow read: if isDevMode() || (isAuthenticated() && userId == request.auth.uid);
      allow create, update: if isDevMode(); // Only Cloud Functions should create/update
      allow delete: if isDevMode() || (isAuthenticated() && userId == request.auth.uid);
    }

    // ==================== BOOKINGS COLLECTION ====================
    // Used for tracking ride bookings (passengers booking rides)
    match /bookings/{bookingId} {
      allow read: if isDevMode() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      ));
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      ));
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ==================== RIDE REQUESTS COLLECTION ====================
    // Used for ride booking requests (riders request rides from drivers)
    match /rideRequests/{requestId} {
      allow read: if isDevMode() || (isAuthenticated() && (
        resource.data.riderId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      ));
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.riderId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && (
        resource.data.riderId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      ));
      allow delete: if isDevMode() || (isAuthenticated() && (
        resource.data.riderId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      ));
    }

    // ==================== MESSAGES COLLECTION (Top-level) ====================
    // Used for standalone messages (delete account cleanup)
    match /messages/{messageId} {
      allow read: if isDevMode() || (isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      ));
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.senderId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.senderId == request.auth.uid);
    }

    // ==================== REVIEWS COLLECTION ====================
    // Used for ride/driver reviews
    match /reviews/{reviewId} {
      allow read: if isDevMode() || isAuthenticated();
      allow create: if isDevMode() || (isAuthenticated() && request.resource.data.reviewerId == request.auth.uid);
      allow update: if isDevMode() || (isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid || 
        resource.data.targetUserId == request.auth.uid
      ));
      allow delete: if isDevMode() || (isAuthenticated() && resource.data.reviewerId == request.auth.uid);
    }

    // ==================== EVENTS COLLECTION ====================
    // Sport events created by users; participants join/leave
    match /events/{eventId} {
      // Any authenticated user can browse events
      allow read: if isDevMode() || isAuthenticated();

      // Only the creator can create their own event
      allow create: if isDevMode() || (
        isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid
      );

      // Creator can fully update the event;
      // any authenticated user can join/leave (participantIds array)
      allow update: if isDevMode() || (
        isAuthenticated() && (
          resource.data.creatorId == request.auth.uid ||
          // Participants can only modify the participantIds array
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['participantIds', 'updatedAt'])
          )
        )
      );

      // Only the creator can delete their event
      allow delete: if isDevMode() || (
        isAuthenticated() && resource.data.creatorId == request.auth.uid
      );
    }

    // ==================== PAYMENTS COLLECTION ====================
    // Payment records written by Cloud Functions (Stripe webhook)
    match /payments/{paymentId} {
      allow read: if isDevMode() || (isAuthenticated() && (
        resource.data.riderId == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      ));
      // Only Cloud Functions write to this collection (via webhook)
      allow create, update, delete: if isDevMode();
    }
  }
}
