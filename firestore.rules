rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCurrentUserPremium() {
      return isAuthenticated() && getUserData().isPremium == true;
    }

    function isEventGroupChat(chatData) {
      return chatData.type == 'eventGroup';
    }

    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;

      return isAuthenticated() &&
        request.auth.uid in chat.participantIds &&
        (!isEventGroupChat(chat) || isCurrentUserPremium());
    }

    function isPassengerBookingCreate() {
      return isAuthenticated() &&
        request.resource.data.passengerId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        !('paymentIntentId' in request.resource.data) &&
        !('paidAt' in request.resource.data);
    }

    function isPassengerBookingUpdate() {
      return isAuthenticated() &&
        resource.data.passengerId == request.auth.uid &&
        changedKeys().hasOnly([
          'status',
          'respondedAt',
          'updatedAt',
          'cancellationReason',
          'cancelledAt'
        ]) &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.rideId == resource.data.rideId &&
        request.resource.data.passengerId == resource.data.passengerId &&
        request.resource.data.driverId == resource.data.driverId;
    }

    function isDriverBookingUpdate(rideId) {
      return isAuthenticated() &&
        (
          resource.data.driverId == request.auth.uid ||
          get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid
        ) &&
        changedKeys().hasOnly([
          'status',
          'respondedAt',
          'updatedAt',
          'pickupOtp',
          'cancellationReason',
          'cancelledAt'
        ]) &&
        request.resource.data.rideId == resource.data.rideId &&
        request.resource.data.passengerId == resource.data.passengerId &&
        request.resource.data.driverId == resource.data.driverId;
    }

    function isOwnRideStatusUpdate() {
      return changedKeys().hasOnly(['rideStatuses', 'updatedAt']) &&
        request.resource.data.rideStatuses
          .diff(resource.data.rideStatuses)
          .affectedKeys()
          .hasOnly([request.auth.uid]);
    }

    function isJoiningEvent() {
      return changedKeys().hasOnly(['participantIds', 'updatedAt']) &&
        !(request.auth.uid in resource.data.participantIds) &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1 &&
        request.resource.data.participantIds.hasAll(resource.data.participantIds);
    }

    function isLeavingEvent() {
      return (
          changedKeys().hasOnly(['participantIds', 'updatedAt']) ||
          changedKeys().hasOnly(['participantIds', 'rideStatuses', 'updatedAt'])
        ) &&
        request.auth.uid in resource.data.participantIds &&
        !(request.auth.uid in request.resource.data.participantIds) &&
        request.resource.data.participantIds.size() == resource.data.participantIds.size() - 1 &&
        resource.data.participantIds.hasAll(request.resource.data.participantIds) &&
        (
          !changedKeys().hasAny(['rideStatuses']) ||
          request.resource.data.rideStatuses
            .diff(resource.data.rideStatuses)
            .affectedKeys()
            .hasOnly([request.auth.uid])
        );
    }

    function isMeetupPinUpdate() {
      return changedKeys().hasOnly([
        'meetupPinLocation',
        'updatedAt'
      ]);
    }

    function isLinkedRideUpdate() {
      return changedKeys().hasOnly([
        'linkedRideIds',
        'updatedAt'
      ]);
    }

    // ---------------------------------------------------------------------
    // Users
    // ---------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) ||
        (
          isAuthenticated() &&
          changedKeys().hasOnly(['rating', 'gamification'])
        );

      allow delete: if isOwner(userId);

      match /blockedUsers/{blockedUserId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---------------------------------------------------------------------
    // Rides
    // ---------------------------------------------------------------------

    match /rides/{rideId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.driverId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (
          resource.data.driverId == request.auth.uid ||
          changedKeys().hasOnly(['bookingIds', 'updatedAt'])
        );

      allow delete: if isAuthenticated() &&
        resource.data.driverId == request.auth.uid;

      match /bookings/{bookingId} {
        allow read: if isAuthenticated() &&
          (
            resource.data.passengerId == request.auth.uid ||
            resource.data.driverId == request.auth.uid ||
            get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid
          );

        allow create: if isPassengerBookingCreate();

        allow update: if isAuthenticated() &&
          (
            isPassengerBookingUpdate() ||
            isDriverBookingUpdate(rideId)
          );

        allow delete: if isAuthenticated() &&
          resource.data.passengerId == request.auth.uid;
      }
    }

    // ---------------------------------------------------------------------
    // Top-level bookings
    // ---------------------------------------------------------------------

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.passengerId == request.auth.uid ||
          resource.data.driverId == request.auth.uid ||
          get(/databases/$(database)/documents/rides/$(resource.data.rideId)).data.driverId == request.auth.uid
        );

      allow create: if isPassengerBookingCreate();

      allow update: if isAuthenticated() &&
        (
          isPassengerBookingUpdate() ||
          isDriverBookingUpdate(resource.data.rideId)
        );

      allow delete: if isAuthenticated() &&
        resource.data.passengerId == request.auth.uid;
    }

    // Collection-group compatible bookings rule.
    match /{path=**}/bookings/{bookingId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.passengerId == request.auth.uid ||
          resource.data.driverId == request.auth.uid ||
          get(/databases/$(database)/documents/rides/$(resource.data.rideId)).data.driverId == request.auth.uid
        );

      allow create: if isPassengerBookingCreate();

      allow update: if isAuthenticated() &&
        (
          isPassengerBookingUpdate() ||
          isDriverBookingUpdate(resource.data.rideId)
        );

      allow delete: if isAuthenticated() &&
        resource.data.passengerId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Chats
    // ---------------------------------------------------------------------

    match /chats/{chatId} {
      allow get: if isAuthenticated() &&
        (
          resource == null ||
          (
            request.auth.uid in resource.data.participantIds &&
            (!isEventGroupChat(resource.data) || isCurrentUserPremium())
          ) ||
          (
            'eventId' in resource.data &&
            resource.data.eventId is string &&
            request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.participantIds &&
            (!isEventGroupChat(resource.data) || isCurrentUserPremium())
          )
        );

      allow list: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;

      allow create: if isAuthenticated() &&
        (
          (
            request.auth.uid in request.resource.data.participantIds &&
            (!isEventGroupChat(request.resource.data) || isCurrentUserPremium())
          ) ||
          (
            'eventId' in request.resource.data &&
            request.resource.data.eventId is string &&
            request.auth.uid in get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.participantIds
          )
        );

      allow update: if isAuthenticated() &&
        (
          // User-specific chat settings.
          (
            request.auth.uid in resource.data.participantIds &&
            changedKeys().hasOnly([
              'mutedBy',
              'pinnedBy',
              'deletedAtBy',
              'clearedAtBy',
              'unreadCounts',
              'updatedAt'
            ])
          ) ||

          // Message send preview update.
          (
            request.auth.uid in resource.data.participantIds &&
            changedKeys().hasOnly([
              'lastMessageContent',
              'lastMessageSenderId',
              'lastMessageSenderName',
              'lastMessageType',
              'lastMessageAt',
              'updatedAt',
              'participantIds',
              'deletedAtBy'
            ]) &&
            request.resource.data.lastMessageSenderId == request.auth.uid
          ) ||

          // Remove self from chat.
          (
            request.auth.uid in resource.data.participantIds &&
            changedKeys().hasOnly(['participantIds', 'updatedAt']) &&
            request.resource.data.participantIds.size() == resource.data.participantIds.size() - 1 &&
            resource.data.participantIds.hasAll(request.resource.data.participantIds) &&
            !(request.auth.uid in request.resource.data.participantIds)
          ) ||

          // Event chat membership/metadata update.
          (
            'eventId' in resource.data &&
            resource.data.eventId is string &&
            request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.participantIds &&
            changedKeys().hasOnly([
              'participantIds',
              'updatedAt'
            ]) &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.eventId == resource.data.eventId &&
            request.resource.data.premiumOnly == resource.data.premiumOnly &&
            request.resource.data.isActive == resource.data.isActive
          )
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          isChatParticipant(chatId);

        allow create: if isAuthenticated() &&
          isChatParticipant(chatId) &&
          request.resource.data.senderId == request.auth.uid;

        allow update: if isAuthenticated() &&
          isChatParticipant(chatId) &&
          (
            resource.data.senderId == request.auth.uid ||
            changedKeys().hasOnly([
              'readBy',
              'deliveredTo',
              'reactions',
              'status',
              'updatedAt'
            ])
          );

        allow delete: if false;
      }

      match /typing/{typingId} {
        allow read, write: if isAuthenticated() &&
          isChatParticipant(chatId);
      }
    }

    // ---------------------------------------------------------------------
    // Notifications
    // ---------------------------------------------------------------------

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Vehicles
    // ---------------------------------------------------------------------

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Driver stats
    // ---------------------------------------------------------------------

    match /driver_stats/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && driverId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Hotspots / Leaderboard
    // ---------------------------------------------------------------------

    match /hotspots/{hotspotId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /leaderboard/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // Transactions
    // ---------------------------------------------------------------------

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.driverId == request.auth.uid ||
          resource.data.riderId == request.auth.uid
        );

      allow create: if isAuthenticated() &&
        (
          request.resource.data.driverId == request.auth.uid ||
          request.resource.data.riderId == request.auth.uid
        );

      allow update, delete: if isAuthenticated() &&
        resource.data.driverId == request.auth.uid;
    }

    match /{path=**}/transactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.driverId == request.auth.uid ||
          resource.data.riderId == request.auth.uid
        );

      allow create: if isAuthenticated() &&
        (
          request.resource.data.driverId == request.auth.uid ||
          request.resource.data.riderId == request.auth.uid
        );

      allow update, delete: if isAuthenticated() &&
        resource.data.driverId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Stripe connected accounts
    // ---------------------------------------------------------------------

    match /driver_connected_accounts/{userId} {
      allow read: if isAuthenticated() &&
        userId == request.auth.uid;

      // Server-owned snapshot. Cloud Functions/Admin SDK only.
      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------------
    // Ride requests
    // ---------------------------------------------------------------------

    match /rideRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.riderId == request.auth.uid ||
          resource.data.driverId == request.auth.uid
        );

      allow create: if isAuthenticated() &&
        request.resource.data.riderId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (
          resource.data.riderId == request.auth.uid ||
          resource.data.driverId == request.auth.uid
        );

      allow delete: if isAuthenticated() &&
        (
          resource.data.riderId == request.auth.uid ||
          resource.data.driverId == request.auth.uid
        );
    }

    // ---------------------------------------------------------------------
    // Top-level standalone messages
    // ---------------------------------------------------------------------

    match /messages/{messageId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        );

      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.senderId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Reviews
    // ---------------------------------------------------------------------

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.reviewerId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Events
    // ---------------------------------------------------------------------

    match /events/{eventId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (
          resource.data.creatorId == request.auth.uid ||

          isJoiningEvent() ||

          isLeavingEvent() ||

          (
            request.auth.uid in resource.data.participantIds &&
            isOwnRideStatusUpdate()
          ) ||

          (
            request.auth.uid in resource.data.participantIds &&
            isMeetupPinUpdate()
          ) ||

          (
            request.auth.uid in resource.data.participantIds &&
            isLinkedRideUpdate()
          )
        );

      allow delete: if isAuthenticated() &&
        resource.data.creatorId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Payments / Payouts
    // ---------------------------------------------------------------------

    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.riderId == request.auth.uid ||
          resource.data.driverId == request.auth.uid
        );

      allow create, update, delete: if false;
    }

    match /payouts/{payoutId} {
      allow read: if isAuthenticated() &&
        resource.data.driverId == request.auth.uid;

      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------------
    // Disputes
    // ---------------------------------------------------------------------

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.complainantId == request.auth.uid ||
          resource.data.respondentId == request.auth.uid
        );

      allow create: if isAuthenticated() &&
        request.resource.data.complainantId == request.auth.uid;

      allow update: if isAuthenticated() &&
        (
          (
            resource.data.complainantId == request.auth.uid &&
            changedKeys().hasOnly([
              'description',
              'attachmentUrls',
              'updatedAt'
            ])
          ) ||
          (
            resource.data.respondentId == request.auth.uid &&
            changedKeys().hasOnly([
              'respondentResponse',
              'respondentEvidence',
              'updatedAt'
            ])
          )
        );

      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Reports
    // ---------------------------------------------------------------------

    match /reports/{reportId} {
      allow read: if isAuthenticated() &&
        resource.data.reporterId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;

      allow update, delete: if false;
    }

    // ---------------------------------------------------------------------
    // Support tickets
    // ---------------------------------------------------------------------

    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow delete: if false;
    }
  }
}
