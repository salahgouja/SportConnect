# SportConnect Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# STRIPE CONFIGURATION
# ============================================

# Stripe Publishable Key (safe for client-side)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ============================================
# FIREBASE CONFIGURATION (Already in google-services.json)
# ============================================
# Firebase is configured via google-services.json and GoogleService-Info.plist
# No additional environment variables needed for Firebase
# Cloud Functions environment is set separately in functions/.env

# ============================================
# APPLE SIGN-IN / IOS REFERENCE VARIABLES
# ============================================
# These are not read by the Flutter app directly today.
# Keep them here so setup can be documented and repeatable.
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID
APPLE_SERVICE_ID=YOUR_APPLE_SERVICE_ID
APPLE_BUNDLE_ID=com.sportconnect.SportConnectApplication
APPLE_PRIVATE_KEY_BASE64=YOUR_BASE64_ENCODED_P8_CONTENT
APPLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID
APPLE_IOS_REVERSED_CLIENT_ID=com.googleusercontent.apps.YOUR_REVERSED_CLIENT_ID
APPLE_FIREBASE_AUTH_HANDLER_URL=https://YOUR_PROJECT_ID.firebaseapp.com/__/auth/handler
APPLE_ASSOCIATED_DOMAIN=sportaxitrip.com
APPLE_ASSOCIATED_DOMAIN_WWW=www.sportaxitrip.com

# ============================================
# IOS PUSH / APNS REFERENCE VARIABLES
# ============================================
# Needed in Firebase Console Cloud Messaging for iOS push delivery.
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_PRIVATE_KEY_BASE64=YOUR_BASE64_ENCODED_APNS_P8_CONTENT

# ============================================
# BUILD COMMANDS
# ============================================
# Run the app with environment variables:
#
# flutter run --dart-define=STRIPE_PUBLISHABLE_KEY=pk_test_xxx
#
# Or use flutter_dotenv package to load from this file
#
# For production builds:
# flutter build apk --dart-define=STRIPE_PUBLISHABLE_KEY=pk_live_xxx

