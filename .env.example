# SportConnect Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# STRIPE CONFIGURATION
# ============================================

# Stripe Publishable Key (safe for client-side)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ============================================
# FIREBASE CONFIGURATION (Already in google-services.json)
# ============================================
# Firebase is configured via google-services.json and GoogleService-Info.plist
# No additional environment variables needed for Firebase
# Cloud Functions environment is set separately in functions/.env

# ============================================
# BUILD COMMANDS
# ============================================
# Run the app with environment variables:
#
# flutter run --dart-define=STRIPE_PUBLISHABLE_KEY=pk_test_xxx
#
# Or use flutter_dotenv package to load from this file
#
# For production builds:
# flutter build apk --dart-define=STRIPE_PUBLISHABLE_KEY=pk_live_xxx

