{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": { "rules": "database.rules.json" },
  "storage": { "rules": "storage.rules" },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/node_modules/**"],
    "headers": [
      {
        "source": "/.well-known/**",
        "headers": [{ "key": "Content-Type", "value": "application/json" }]
      }
    ],
    "rewrites": [{ "source": "/ride/**", "destination": "/ride/index.html" }]
  },
  "functions": [
    {
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "source": "functions"
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "marathon-connect",
          "appId": "1:950804897667:android:336cec4dff83493780e0b6",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "marathon-connect",
          "configurations": {
            "ios": "1:950804897667:ios:ee25c791f879565e80e0b6"
          }
        }
      }
    }
  },
  "emulators": {
    "auth": { "port": 9099, "host": "0.0.0.0" },
    "functions": { "port": 5001, "host": "0.0.0.0" },
    "firestore": { "port": 8080, "host": "0.0.0.0" },
    "database": { "port": 9000, "host": "0.0.0.0" },
    "storage": { "port": 9199, "host": "0.0.0.0" },
    "ui": { "enabled": true, "port": 4000, "host": "0.0.0.0" },
    "singleProjectMode": true
  }
}
