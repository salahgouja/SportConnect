# Fastfile for SportConnect
# Requires: fastlane >= 2.222.0
#
# Android lanes:
#   bundle exec fastlane android internal   → Play Store internal testing track
#   bundle exec fastlane android production → Play Store production track
#
# iOS lanes:
#   bundle exec fastlane ios beta           → TestFlight internal testing
#   bundle exec fastlane ios release        → App Store production submit

# ─────────────────────────────────────────
# Shared helpers
# ─────────────────────────────────────────

before_all do
  # Verify required secrets are present
end

# ─────────────────────────────────────────
# Android
# ─────────────────────────────────────────
platform :android do

  desc "Upload a signed AAB to the Play Store internal testing track"
  lane :internal do
    upload_to_play_store(
      package_name:       "com.sportconnect.sport_connect",
      track:              "internal",
      aab:                "build/app/outputs/bundle/release/app-release.aab",
      json_key_data:      ENV["PLAY_STORE_JSON_KEY"],
      skip_upload_apk:    true,
      release_status:     "completed",  # makes it immediately available to internal testers
      rollout:            "1.0"
    )
  end

  desc "Promote the current internal build to production"
  lane :production do
    upload_to_play_store(
      package_name:       "com.sportconnect.sport_connect",
      track:              "internal",
      track_promote_to:   "production",
      json_key_data:      ENV["PLAY_STORE_JSON_KEY"],
      skip_upload_apk:    true,
      skip_upload_aab:    true,
      rollout:            "0.1"         # 10% staged rollout
    )
  end

end

# ─────────────────────────────────────────
# iOS
# ─────────────────────────────────────────
platform :ios do

  desc "Push a signed IPA to TestFlight for internal testing"
  lane :beta do
    # Required in CI to avoid interactive prompts and keychain conflicts
    setup_ci if ENV["CI"]

    # Use App Store Connect API key (preferred over password — no 2FA issues)
    api_key = app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_API_KEY"],  # base64-encoded .p8 content
      is_key_content_base64: true,
      in_house:              false
    )

    # Sync certificates and provisioning profiles from private Match repo
    match(
      type:    "appstore",
      readonly: true,
      api_key: api_key
    )

    # Build signed IPA
    build_app(
      workspace:      "ios/Runner.xcworkspace",
      scheme:         "Runner",
      configuration:  "Release",
      export_method:  "app-store",
      export_options: {
        provisioningProfiles: {
          "com.sportconnect.SportConnectApplication" =>
            "match AppStore com.sportconnect.SportConnectApplication"
        }
      },
      output_directory: "build/ios/ipa",
      output_name:      "SportConnect.ipa"
    )

    # Upload to TestFlight — skip waiting for Apple's processing
    upload_to_testflight(
      api_key:                          api_key,
      ipa:                              "build/ios/ipa/SportConnect.ipa",
      skip_waiting_for_build_processing: true,
      notify_external_testers:          false   # internal only
    )
  end

  desc "Submit the latest TestFlight build to App Store review"
  lane :release do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id:                ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:             ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:           ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true,
      in_house:              false
    )

    deliver(
      api_key:         api_key,
      submit_for_review: true,
      automatic_release: false,
      force:             true,      # skip HTML preview
      skip_screenshots:  true,
      skip_metadata:     true
    )
  end

end
