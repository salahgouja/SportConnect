default_platform(:android)

platform :android do

  # ── deploy ─────────────────────────────────────────────────────────────
  # Called by CI with: bundle exec fastlane android deploy track:<track>
  # Defaults to internal if no track is passed.
  desc "Upload the signed AAB to the Play Store"
  lane :deploy do |options|
    track = options[:track] || "internal"

    # Derive the version name from the current git tag (e.g. v1.2.3 → 1.2.3)
    version_name = last_git_tag.sub(/^v/, "")

    # Auto-increment the build number from the Play Store's current value
    # so we never have to manually bump it in pubspec.yaml
    build_number = google_play_track_version_codes(
      package_name:    CredentialsManager::AppfileConfig.try_fetch_value(:package_name),
      track:           "internal",    # always read from internal — it's the source of truth
      json_key_data:   ENV["PLAY_STORE_JSON_KEY"]
    ).max.to_i + 1

    UI.message("Deploying #{version_name} (#{build_number}) to #{track}")

    # Build changelog from git log since the previous tag
    changelog = changelog_from_git_commits(
      between:         [last_git_tag(pattern: "v*~1"), "HEAD"],
      pretty:          "- %s",
      merge_commit_filtering: "exclude_merges"
    )
    changelog = "No changes listed." if changelog.nil? || changelog.strip.empty?

    upload_to_play_store(
      package_name:             CredentialsManager::AppfileConfig.try_fetch_value(:package_name),
      track:                    track,
      aab:                      "build/app/outputs/bundle/release/app-release.aab",
      json_key_data:            ENV["PLAY_STORE_JSON_KEY"],
      version_name:             version_name,
      version_code:             build_number,
      release_status:           track == "production" ? "completed" : "draft",
      # Send changelog as release notes (English default; add more locales below)
      release_notes: {
        "en-US" => changelog[0, 500]   # Play Store caps release notes at 500 chars
      },
      skip_upload_apk:          true,
      skip_upload_metadata:     true,
      skip_upload_changelogs:   false,
      skip_upload_images:       true,
      skip_upload_screenshots:  true
    )

    UI.success("Successfully deployed #{version_name} (#{build_number}) to #{track}")
  end

  # ── Error handler ───────────────────────────────────────────────────────
  error do |lane, exception, options|
    UI.error("Lane #{lane} failed with: #{exception.message}")
    # Re-raise so the CI job exits non-zero and the workflow failure
    # notification fires correctly
    raise exception
  end

end
